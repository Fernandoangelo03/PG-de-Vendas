<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Onda de la Atención - Método Científico</title>
    <!-- Google Fonts para Design Premium -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-dark: #0a0d1a;
            --bg-card: rgba(20, 25, 45, 0.7);
            --primary: #6366f1;
            --secondary: #a855f7;
            --accent: #10b981;
            --text-light: #f3f4f6;
            --text-muted: #9ca3af;
            --warning: #f97316;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            overflow-x: hidden;
            line-height: 1.6;
        }

        h1, h2, h3, .headline {
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* --- TOP BAR / AVISO --- */
        .top-bar {
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            text-align: center;
            padding: 8px 10px;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        /* --- HERO SECTION --- */
        header {
            position: relative;
            padding: 80px 0 60px 0;
            text-align: center;
            background: radial-gradient(circle at top, rgba(99, 102, 241, 0.15) 0%, transparent 60%);
        }

        .pre-headline {
            color: var(--warning);
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.95rem;
            letter-spacing: 2px;
            margin-bottom: 15px;
            display: inline-block;
        }

        h1 {
            font-size: 2.8rem;
            line-height: 1.2;
            margin-bottom: 25px;
            background: linear-gradient(120deg, #fff 30%, #c7d2fe 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sub-headline {
            font-size: 1.2rem;
            color: var(--text-muted);
            max-width: 800px;
            margin: 0 auto 35px auto;
            font-weight: 300;
        }

        /* --- BOTÃO DE CHAMADA PRINCIPAL (CTA) --- */
        .cta-button {
            display: inline-block;
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            padding: 20px 40px;
            font-family: 'Montserrat', sans-serif;
            font-size: 1.2rem;
            font-weight: 800;
            text-decoration: none;
            border-radius: 50px;
            box-shadow: 0 10px 25px rgba(16, 185, 129, 0.4);
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            animation: pulse 2s infinite;
        }

        .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(16, 185, 129, 0.6);
        }

        .cta-subtext {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-top: 12px;
        }

        /* --- SEÇÃO DO PROBLEMA / DOR --- */
        .problem-section {
            padding: 80px 0;
            background-color: rgba(15, 18, 36, 0.5);
        }

        .section-title {
            text-align: center;
            font-size: 2rem;
            margin-bottom: 40px;
            position: relative;
        }

        .section-title::after {
            content: '';
            display: block;
            width: 60px;
            height: 4px;
            background: var(--secondary);
            margin: 15px auto 0 auto;
            border-radius: 2px;
        }

        .grid-problem {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            align-items: center;
        }

        .problem-text p {
            margin-bottom: 20px;
            color: var(--text-muted);
            font-size: 1.05rem;
        }

        .problem-text strong {
            color: var(--text-light);
        }

        .highlight-card {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 30px;
            border-radius: 20px;
            backdrop-filter: blur(10px);
            border-left: 5px solid var(--primary);
        }

        .highlight-card h3 {
            color: #fff;
            margin-bottom: 15px;
        }

        /* --- SEÇÃO DA SOLUÇÃO --- */
        .solution-section {
            padding: 80px 0;
            background: radial-gradient(circle at bottom right, rgba(168, 85, 247, 0.1) 0%, transparent 50%);
        }

        .waves-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-top: 40px;
        }

        .wave-card {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 30px;
            border-radius: 20px;
            text-align: center;
            transition: transform 0.3s ease;
        }

        .wave-card:hover {
            transform: translateY(-5px);
        }

        .wave-icon {
            font-size: 3rem;
            margin-bottom: 15px;
            display: inline-block;
        }

        .wave-card.diurna .wave-icon { color: #f59e0b; text-shadow: 0 0 20px rgba(245,158,11,0.2); }
        .wave-card.nocturna .wave-icon { color: #3b82f6; text-shadow: 0 0 20px rgba(59,130,246,0.2); }

        .wave-card h3 {
            margin-bottom: 15px;
            font-size: 1.4rem;
        }

        /* --- CONTEÚDO POR DENTRO (GAMIFICAÇÃO) --- */
        .inside-section {
            padding: 80px 0;
            background-color: rgba(15, 18, 36, 0.5);
        }

        .grid-modules {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-top: 40px;
        }

        .module-card {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.03);
            border-radius: 15px;
            padding: 25px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .module-badge {
            background: var(--secondary);
            font-size: 0.75rem;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 20px;
            display: inline-block;
            margin-bottom: 15px;
            text-transform: uppercase;
        }

        .module-card.bonus .module-badge {
            background: var(--warning);
        }

        .module-card h4 {
            font-size: 1.1rem;
            margin-bottom: 10px;
        }

        .module-card p {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        /* --- PREÇO / OFERTA --- */
        .offer-section {
            padding: 90px 0;
            text-align: center;
            background: linear-gradient(180deg, transparent, rgba(99, 102, 241, 0.08), transparent);
        }

        .pricing-box {
            background: linear-gradient(145deg, rgba(25, 30, 55, 0.9) 0%, rgba(15, 18, 36, 0.9) 100%);
            border: 2px solid var(--primary);
            max-width: 550px;
            margin: 0 auto;
            border-radius: 30px;
            padding: 50px 40px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            position: relative;
        }

        .old-price {
            font-size: 1.3rem;
            color: var(--text-muted);
            text-decoration: line-through;
            margin-bottom: 5px;
        }

        .new-price {
            font-size: 4rem;
            font-weight: 800;
            font-family: 'Montserrat', sans-serif;
            color: #fff;
            line-gradient: linear-gradient(to bottom, #fff, #9ca3af);
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .new-price span {
            font-size: 1.8rem;
            vertical-align: super;
            margin-right: 5px;
        }

        /* --- CONTADOR --- */
        .timer-box {
            margin: 25px 0;
            background: rgba(249, 115, 22, 0.1);
            border: 1px dashed var(--warning);
            padding: 12px;
            border-radius: 12px;
            display: inline-flex;
            gap: 10px;
            align-items: center;
            font-weight: 600;
            color: var(--warning);
        }

        /* --- GARANTIA --- */
        .warranty-section {
            padding: 60px 0;
        }

        .warranty-box {
            display: flex;
            align-items: center;
            gap: 40px;
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 40px;
            border-radius: 25px;
            max-width: 850px;
            margin: 0 auto;
        }

        .warranty-badge {
            font-size: 4.5rem;
            line-height: 1;
        }

        .warranty-text h3 {
            font-size: 1.4rem;
            margin-bottom: 10px;
        }

        .warranty-text p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* --- FAQ / ACORDEON --- */
        .faq-section {
            padding: 80px 0 100px 0;
        }

        .faq-container {
            max-width: 750px;
            margin: 40px auto 0 auto;
        }

        .faq-item {
            background: var(--bg-card);
            border: 1px solid rgba(255,255,255,0.04);
            margin-bottom: 15px;
            border-radius: 12px;
            overflow: hidden;
        }

        .faq-question {
            padding: 20px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            user-select: none;
            transition: background 0.3s ease;
        }

        .faq-question:hover {
            background: rgba(255,255,255,0.02);
        }

        .faq-answer {
            padding: 0 20px;
            max-height: 0;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0, 1, 0, 1);
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .faq-item.active .faq-answer {
            max-height: 1000px;
            padding: 0 20px 20px 20px;
        }

        .faq-icon::after {
            content: '+';
            font-size: 1.3rem;
            color: var(--primary);
            font-weight: bold;
        }

        .faq-item.active .faq-icon::after {
            content: '−';
        }

        /* --- FOOTER --- */
        footer {
            background: #05070f;
            padding: 40px 0;
            text-align: center;
            font-size: 0.85rem;
            color: var(--text-muted);
            border-top: 1px solid rgba(255,255,255,0.02);
        }

        /* --- ANIMAÇÕES --- */
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.02); }
